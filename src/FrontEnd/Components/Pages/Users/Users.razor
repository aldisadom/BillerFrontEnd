@page "/users"
@using Clients.Clients
@using Clients.Interfaces
@using Common
@using Contracts.Responses.User
@using Microsoft.AspNetCore.Components.QuickGrid

@inject IUserClient _userClient
@inject NavigationManager _navigationManager

@attribute [StreamRendering]
@rendermode InteractiveServer

<PageTitle>Users</PageTitle>
<div style="display: flex; align-items: center;">
    <h1>Users</h1>
    <div style="margin-left: 20px;">
        <button @onclick="AddClick">Add</button>
    </div>
</div>

@if (_error != null)
{
    <h1>Error</h1>
    @_error.Message
    <br />
    @_error.ExtendedMessage
    <br />
}
@if (_userList == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="card">
        <div class="card-header">
        </div>
        <div class="card-body">
            <QuickGrid Items="@_usersQueryable" Pagination="_pagination">
                <PropertyColumn Title="Email" Property="@(i => i.Email)" Sortable="true" Align="Align.Left" Class=" country-name">
                    <ColumnOptions>
                        <div class="search-box">
                            <input type="search" autofocus @onchange="SearchByName" placeholder="User email..." />
                        </div>
                    </ColumnOptions>
                </PropertyColumn>
                <PropertyColumn Title="Name" Property="@(i => i.Name)" Align="Align.Right" />
                <PropertyColumn Title="Last name" Property="@(i => i.LastName)" Align="Align.Right" />                
                <!--   <PropertyColumn Property="@(p => p.da)" Format="yyyy-MM-dd" Sortable="true" /> -->
                <TemplateColumn Title="Action">
                    <button @onclick="@(() => Edit(context))" class="btn btn-info">Edit</button>
                    <button @onclick="@(() => Delete(context))" class="btn btn-danger">Delete</button>
                </TemplateColumn>
            </QuickGrid>
        </div>
        <div class="card-footer"><Paginator State="@_pagination" /></div>
    </div>
}

@code {
    private UserListResponse? _userList;
    private PaginationState _pagination = new PaginationState { ItemsPerPage = 50 };
    private IQueryable<UserResponse> _usersQueryable = Enumerable.Empty<UserResponse>().AsQueryable();
    private ErrorModel? _error;

    async Task GetData()
    {
        var userResponse = await _userClient.Get();
        bool sucess = userResponse.Match(
            users =>
            {
                _userList = users;
                return true;
            },
            error =>
            {
                _error = error;
                return false;
            }
        );

        if (!sucess || _userList is null)
            return;

        _usersQueryable = _userList.Users.AsQueryable();
    }

    protected override async Task OnInitializedAsync()
    {
        await GetData();
    }

    void SearchByName(ChangeEventArgs e)
    {

    }

    void Edit(UserResponse user)
    {
        _navigationManager.NavigateTo($"/users/{user.Id}", false);
    }

    async Task Delete(UserResponse user)
    {
        await _userClient.Delete(user.Id);
        await GetData();
    }

    private void AddClick()
    {
        _navigationManager.NavigateTo($"/users/add", false);
    }
}
