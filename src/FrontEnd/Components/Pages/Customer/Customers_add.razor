@page "/customers/add"
@using Clients.Clients
@using Clients.Interfaces
@using Common
@using Contracts.Requests.Customer
@using Contracts.Responses
@using Contracts.Responses.Customer
@using Domain.Exceptions

@inject NavigationManager _navigationManager
@inject ICustomerClient _customerClient

@attribute [StreamRendering]
@rendermode InteractiveServer

<PageTitle>Invoice address add</PageTitle>

<div style="display: flex; align-items: center;">
    <div style="margin-left: 20px;">
    <button @onclick="AddClick">Add</button>
    </div>      
</div>

@if (_error != null)
{
    <h1>Error</h1>
    @_error.Message
    <br />
    @_error.ExtendedMessage
    <br />
}
<b>SellerId:</b>
<br />
<input type="text" @bind="customer.SellerId" />
<br />
<b>Company name:</b>
<br />
<input type="text" @bind="customer.CompanyName" />
<br />
<b>Company number:</b>
<br />
<input type="text" @bind="customer.CompanyNumber" />
<br />
<b>Invoice name:</b>
<br />
<input type="text" @bind="customer.InvoiceName" />
<br />
<b>Email:</b>
<br />
<input type="text" @bind="customer.Email" />
<br />
<b>Phone:</b>
<br />
<input type="text" @bind="customer.Phone" />
<br />
<b>State:</b>
<br />
<input type="text" @bind="customer.State" />
<br />
<b>City:</b>
<br />
<input type="text" @bind="customer.City" />
<br />
<b>Street:</b>
<br />
<input type="text" @bind="customer.Street" />

@code {
    private CustomerAddRequest customer = new();
    private ErrorModel? _error;

    protected override async Task OnInitializedAsync()
    {
    }

    private async Task AddClick()
    {
        var response = await _customerClient.Add(customer);

        bool sucess = response.Match(
            addResponse => { 
                _navigationManager.NavigateTo($"/customers/{addResponse.Id}", false);
                _error = null;
                return true;
            },
            error => {
                _error = error;
                return false;
            }
        );        
    }
}
